# ============================================
# BeaverCalc Studio — Backend Environment
# ============================================
# Copy this file to .env and fill in the values.
# In development, SECRET_KEY and JWT_SECRET_KEY auto-generate if unset.

# ---------- Flask ----------
FLASK_ENV=development          # development | production
DEBUG=False

# ---------- Security (REQUIRED in production) ----------
SECRET_KEY=change-me-to-a-random-secret
JWT_SECRET_KEY=change-me-to-another-random-secret
ADMIN_DEFAULT_PASSWORD=          # leave blank to auto-generate on first run

# ---------- Database ----------
DATABASE_URL=sqlite:///beaver_calc.db
# For Docker / production use PostgreSQL:
# DATABASE_URL=postgresql://beaver_calc:password@localhost:5432/beaver_calc

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000

# ---------- Rate Limiting ----------
RATELIMIT_DEFAULT=200 per minute
RATELIMIT_STORAGE_URI=memory://
# For Redis-backed rate limiting:
# RATELIMIT_STORAGE_URI=redis://localhost:6379/1

# ---------- File Uploads ----------
UPLOAD_FOLDER=uploads
# MAX_CONTENT_LENGTH is 50 MB by default (set in config.py)
