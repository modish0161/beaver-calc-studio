                          <FiEdit3 size={16} />
                        </Button>
                        <Button variant="ghost" size="sm">
                          <FiDownload size={16} />
                        </Button>
                        <Button variant="ghost" size="sm" className="text-red-400 hover:text-red-300">
                          <FiTrash2 size={16} />
                        </Button>
                      </div>
                    </div>
                    <div className="grid grid-cols-4 gap-6 text-sm">
                      <div>
                        <span className="text-gray-400 block mb-1">Project</span>
                        <span className="text-white font-medium">{run.projectName}</span>
                      </div>
                      <div>
                        <span className="text-gray-400 block mb-1">Run ID</span>
                        <span className="text-white font-mono text-xs">{run.id}</span>
                      </div>
                      <div>
                        <span className="text-gray-400 block mb-1">Created</span>
                        <span className="text-white">{run.createdAt}</span>
                      </div>
                      <div>
                        <span className="text-gray-400 block mb-1">Designer</span>
                        <span className="text-white">{run.createdBy}</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        </div>
      )}
    </div>
  )
}

export default Projects
