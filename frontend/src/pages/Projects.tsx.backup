        return 'text-blue-400 bg-blue-500/20 border-blue-500/40'
      case 'failed':
        return 'text-red-400 bg-red-500/20 border-red-500/40'
      case 'draft':
      case 'archived':
        return 'text-gray-400 bg-gray-500/20 border-gray-500/40'
