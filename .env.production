# BeaverCalc Studio — Production Environment
# Copy this to .env on your VPS and fill in secure values

FLASK_ENV=production
NODE_ENV=production

# Database
POSTGRES_DB=beaver_calc
POSTGRES_USER=beaver_calc
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# Redis
REDIS_URL=redis://redis:6379/0

# Secrets — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_SECRET
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_JWT_SECRET
