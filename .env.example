# BeaverCalc Studio — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# PostgreSQL
POSTGRES_DB=beaver_calc
POSTGRES_USER=beaver_calc
POSTGRES_PASSWORD=<generate-a-strong-password>

# Backend
FLASK_ENV=development
SECRET_KEY=<generate-a-random-secret-key>
JWT_SECRET_KEY=<generate-a-random-jwt-secret>
ADMIN_DEFAULT_PASSWORD=<set-initial-admin-password>

# Redis (default, no password)
REDIS_URL=redis://redis:6379/0

# Frontend
NODE_ENV=development
VITE_API_URL=/api
